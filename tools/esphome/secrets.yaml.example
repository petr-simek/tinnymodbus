# Rename this file to secrets.yaml and fill in your values

wifi_ssid: "YourWiFiSSID"
wifi_password: "your-wifi-password"

# Fallback AP password when WiFi is unavailable
ap_password: "fallback-password"

# API encryption key (generate with: esphome config.yaml and copy from output)
api_key: "your-32-character-api-key-here"

# OTA update password
ota_password: "your-ota-password"
